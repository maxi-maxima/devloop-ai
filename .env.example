OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

GITHUB_TOKEN=replace-with-github-token

# Optional provider overrides for V1 commands
OLLAMA_BASE_URL=http://127.0.0.1:11434
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# GitHub App mode (V2)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=replace-with-escaped-private-key-or-file-loader
GITHUB_WEBHOOK_SECRET=replace-with-random-local-secret
GITHUB_APP_CLIENT_ID=Iv1.placeholder
GITHUB_APP_CLIENT_SECRET=replace-with-local-client-secret
DEVLOOP_APP_BASE_URL=http://localhost:8787
DEVLOOP_APP_PORT=8787
DEVLOOP_APP_DB=.devloop/devloop-app.sqlite
DEVLOOP_ALLOW_LOCAL_RUNNER=false
DEVLOOP_ALLOW_NETWORK=false

# Organization fleet mode
DEVLOOP_ORG_CONFIG=devloop-org.yml
